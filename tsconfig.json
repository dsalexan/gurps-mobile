{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "ES2020"],
    "types": ["@league-of-foundry-developers/foundry-vtt-types", "./types/gurps"],
    "esModuleInterop": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "jsx": "react"
  },
  "include": ["src", "src/**/*.d.ts", "types/*/index.d.ts"]
}
